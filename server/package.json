{
  "name": "api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "dotenv -e .env.development -- tsx watch src/server.ts",
    "prod": "dotenv -e .env.production -- tsx src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "start:prod": "dotenv -e .env.production -- node dist/server.js",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:stop": "pm2 stop brandme-api",
    "pm2:restart": "pm2 restart brandme-api",
    "pm2:delete": "pm2 delete brandme-api",
    "pm2:logs": "pm2 logs brandme-api",
    "pm2:status": "pm2 status",
    "pm2:monit": "pm2 monit",
    "pm2:save": "pm2 save",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "seed": "dotenv -e .env.development -- tsx src/scripts/seedOnStart.ts",
    "migrate:add-user-role": "dotenv -e .env.development -- tsx src/scripts/migrateAddUserRole.ts",
    "migrate:posts": "NODE_ENV=development tsx src/scripts/migratePostsContentFormat.ts",
    "migrate:posts:prod": "NODE_ENV=production tsx src/scripts/migratePostsContentFormat.ts",
    "migrate:asset-urls": "dotenv -e .env.development -- tsx src/scripts/migrateAssetUrls.ts",
    "migrate:asset-urls:prod": "dotenv -e .env.production -- tsx src/scripts/migrateAssetUrls.ts",
    "migrate:order-numbers": "dotenv -e .env.development -- tsx src/scripts/migrateOrderNumbers.ts",
    "migrate:order-numbers:prod": "dotenv -e .env.production -- tsx src/scripts/migrateOrderNumbers.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.901.0",
    "@aws-sdk/s3-request-presigner": "^3.901.0",
    "@supabase/storage-js": "^2.12.2",
    "@supabase/supabase-js": "^2.58.0",
    "@types/multer": "^2.0.0",
    "@types/pdfkit": "^0.17.4",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.60.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.19.2",
    "express-rate-limit": "^7.2.0",
    "google-auth-library": "^10.5.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.8.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.18.0",
    "morgan": "^1.10.0",
    "multer": "^2.0.2",
    "mysql2": "^3.16.0",
    "nodemailer": "^8.0.1",
    "pm2": "^5.4.2",
    "sequelize": "^6.37.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.23",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.19.21",
    "@types/nodemailer": "^7.0.10",
    "@types/sequelize": "^4.28.20",
    "dotenv-cli": "^10.0.0",
    "eslint": "^9.9.1",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
