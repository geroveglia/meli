# URL del API backend
VITE_API_URL=http://localhost:8080/api/v1

# Idioma por defecto
VITE_DEFAULT_LOCALE=es

# Nombre de la aplicación
VITE_APP_FIRST_NAME=Temp
VITE_APP_LAST_NAME=late
# Slug del tenant principal (debe coincidir con SEED_TENANT_SLUG del backend)
VITE_TENANT_SLUG=demo-tenant

# URL de Creative Suite (opcional)
VITE_CREATIVE_SUITE_URL=https://autolab.fun/

# Deploy Hook de Vercel (opcional, solo para development)
# Obtener desde: https://vercel.com/[tu-proyecto]/settings/git
VITE_VERCEL_DEPLOY_HOOK_URL=
